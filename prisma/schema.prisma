// Reserve Já — schema de dados
//
// Convenções:
// - IDs cuid (curtos, sortáveis, URL-safe)
// - Datas em UTC; conversão pra timezone do estabelecimento na UI/availability
// - Booking.publicToken é gerado no application layer (crypto.randomBytes)
//   pra ser realmente unguessable (cuid é só time-ordered)

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: a URL fica em `prisma.config.ts`, não no schema.
datasource db {
  provider = "postgresql"
}

// =========================================================================
// Auth & usuários
// =========================================================================

enum Role {
  ADMIN
  OWNER
}

model User {
  id            String                @id @default(cuid())
  email         String                @unique
  passwordHash  String
  name          String
  role          Role                  @default(OWNER)
  memberships   Membership[]
  resetTokens   PasswordResetToken[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

// Token de reset de senha. Guardamos só o hash (SHA-256) — quem tem o token
// raw é quem clicou no link do email. usedAt previne reuso.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime  @db.Timestamptz(3)
  usedAt    DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId])
}

enum MembershipRole {
  OWNER
  STAFF
}

// Membership liga User à Organization (empresa/marca). Por padrão tem acesso
// a TODAS as unidades da org. Se houver linhas em MembershipUnit pra essa
// membership, o acesso é restrito às unidades listadas (per-unit ACL).
model Membership {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole   @default(OWNER)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  units          MembershipUnit[]
  createdAt      DateTime         @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// Restringe uma Membership a unidades específicas. Sem linhas = acesso total
// (caso comum do OWNER). Usado pra limitar STAFF a 1-2 unidades.
model MembershipUnit {
  membershipId    String
  establishmentId String
  membership      Membership    @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  @@id([membershipId, establishmentId])
  @@index([establishmentId])
}

// =========================================================================
// Organização (empresa/marca) e Estabelecimento (unidade/filial)
// =========================================================================

enum OrgStatus {
  ACTIVE
  TRIAL
  SUSPENDED
}

enum BusinessCategory {
  BARBEARIA
  SALAO_BELEZA
  MANICURE_PEDICURE
  ESTETICA
  MASSAGEM_TERAPIA
  MECANICA_AUTO
  LAVA_RAPIDO
  PET_SHOP
  CLINICA_SAUDE
  ESTUDIO_TATUAGEM
  OUTRO
}

// Empresa/marca. Concentra: status do plano, billing, taxId (CPF ou CNPJ),
// categoria, e os limites de plano (quantas unidades e usuários a org pode
// ter). Uma Organization tem 1+ Establishment.
model Organization {
  id             String           @id @default(cuid())
  name           String
  category       BusinessCategory @default(OUTRO)
  taxId          String?          // CPF (11 dígitos) ou CNPJ (14 dígitos), só dígitos
  status         OrgStatus        @default(TRIAL)
  planLimitUnits Int              @default(1)
  planLimitUsers Int              @default(2)
  establishments Establishment[]
  memberships    Membership[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

// Unidade física do negócio. Carrega slug público, horário, serviços,
// profissionais, bloqueios e bookings. Pertence a uma Organization.
model Establishment {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String         @unique
  name           String
  description    String?
  whatsapp       String
  timezone       String         @default("America/Sao_Paulo")
  logoUrl        String?
  coverUrl       String?
  workingHours   WorkingHour[]
  services       Service[]
  professionals  Professional[]
  bookings       Booking[]
  blocks         TimeBlock[]
  memberUnits    MembershipUnit[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
}

model WorkingHour {
  id              String        @id @default(cuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  weekday         Int           // 0 = domingo, 6 = sábado
  startMin        Int           // minutos desde 00:00 (540 = 09:00)
  endMin          Int

  @@index([establishmentId])
}

// =========================================================================
// Serviços & profissionais
// =========================================================================

model Service {
  id              String                @id @default(cuid())
  establishmentId String
  establishment   Establishment         @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  durationMin     Int
  priceCents      Int
  active          Boolean               @default(true)
  professionals   ProfessionalService[]
  bookings        Booking[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([establishmentId])
}

model Professional {
  id              String                 @id @default(cuid())
  establishmentId String
  establishment   Establishment          @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  name            String
  photoUrl        String?
  active          Boolean                @default(true)
  services        ProfessionalService[]
  schedules       ProfessionalSchedule[]
  blocks          TimeBlock[]
  bookings        Booking[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([establishmentId])
}

model ProfessionalService {
  professionalId String
  serviceId      String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
  @@index([serviceId])
}

model ProfessionalSchedule {
  id             String       @id @default(cuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  weekday        Int
  startMin       Int
  endMin         Int

  @@index([professionalId])
}

// =========================================================================
// Bookings
// =========================================================================

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum CancelledBy {
  CLIENT
  ESTABLISHMENT
  SYSTEM
}

model Booking {
  id              String        @id @default(cuid())
  publicToken     String        @unique
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  professionalId  String
  professional    Professional  @relation(fields: [professionalId], references: [id])
  serviceId       String
  service         Service       @relation(fields: [serviceId], references: [id])
  clientName      String
  clientPhone     String        // E.164: +5511999999999
  startsAt        DateTime      @db.Timestamptz(3)
  endsAt          DateTime      @db.Timestamptz(3)
  status          BookingStatus @default(CONFIRMED)
  cancelledAt     DateTime?     @db.Timestamptz(3)
  cancelledBy     CancelledBy?
  reminderSentAt  DateTime?     @db.Timestamptz(3)
  notes           String?
  createdAt       DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @db.Timestamptz(3)

  @@index([professionalId, startsAt])
  @@index([establishmentId, startsAt])
  @@index([clientPhone])
  // Cron de lembretes filtra por (startsAt, reminderSentAt IS NULL)
  @@index([startsAt, reminderSentAt])
}

// Bloqueios: feriado, almoço, folga. Pode ser do estabelecimento inteiro
// (professionalId null) ou de um profissional específico.
model TimeBlock {
  id              String         @id @default(cuid())
  establishmentId String?
  establishment   Establishment? @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  professionalId  String?
  professional    Professional?  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  startsAt        DateTime       @db.Timestamptz(3)
  endsAt          DateTime       @db.Timestamptz(3)
  reason          String?
  createdAt       DateTime       @default(now()) @db.Timestamptz(3)

  @@index([professionalId, startsAt])
  @@index([establishmentId, startsAt])
}
